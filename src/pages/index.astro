---
import Layout from "../layouts/Layout.astro";
import DependencyGraph from "../components/DependencyGraph.vue";
---

<Layout title="Flutter Graph - Visualizador de dependencias">
  <main
    class="min-h-screen bg-gradient-to-br from-blue-50 via-white to-purple-50"
  >
    <!-- Header -->
    <div class="container mx-auto px-4 py-8">
      <div class="text-center mb-8">
        <div class="inline-flex items-center gap-3 mb-4">
          <div
            class="w-12 h-12 bg-gradient-to-br from-blue-600 to-purple-600 rounded-xl flex items-center justify-center shadow-lg"
          >
            <span class="text-2xl">📦</span>
          </div>
          <h1
            class="text-4xl md:text-5xl font-bold bg-gradient-to-r from-blue-600 to-purple-600 bg-clip-text text-transparent"
          >
            flutter-graph
          </h1>
        </div>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">
          Explore Flutter package dependencies with an interactive graph
          visualization. Enter a package name to see its relationships in a
          clear, visual format.
        </p>
      </div>

      <!-- Main Card -->
      <div class="max-w-6xl mx-auto">
        <div
          class="bg-white rounded-2xl shadow-xl border border-gray-100 overflow-hidden"
        >
          <DependencyGraph client:load />
        </div>
      </div>

      <!-- Features -->
      <div class="grid md:grid-cols-3 gap-6 mt-12 max-w-4xl mx-auto">
        <div
          class="bg-white/60 backdrop-blur-sm rounded-xl p-6 border border-gray-200"
        >
          <div class="text-3xl mb-3">🔍</div>
          <h3 class="font-semibold text-gray-900 mb-2">Deep exploration</h3>
          <p class="text-sm text-gray-600">
            Control the analysis depth to see dependencies of dependencies
          </p>
        </div>
        <div
          class="bg-white/60 backdrop-blur-sm rounded-xl p-6 border border-gray-200"
        >
          <div class="text-3xl mb-3">📊</div>
          <h3 class="font-semibold text-gray-900 mb-2">Complete metrics</h3>
          <p class="text-sm text-gray-600">
            View likes, downloads and pub points for each package
          </p>
        </div>
        <div
          class="bg-white/60 backdrop-blur-sm rounded-xl p-6 border border-gray-200"
        >
          <div class="text-3xl mb-3">🎨</div>
          <h3 class="font-semibold text-gray-900 mb-2">Interactive view</h3>
          <p class="text-sm text-gray-600">
            Navigate and explore the graph with zoom, pan and informative
            tooltips
          </p>
        </div>
      </div>

      <!-- Support Section -->
      <div class="mt-12 text-center">
        <div
          class="inline-block bg-linear-to-r from-blue-50 to-purple-50 rounded-2xl p-8 border border-blue-100"
        >
          <p class="text-gray-700 mb-4 max-w-md">
            ☕ Enjoying <strong>flutter-graph</strong>? Support its development!
          </p>

          <a
            href="https://www.buymeacoffee.com/ajomuch92"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-6
          py-3 bg-linear-to-r from-yellow-400 to-yellow-500 text-gray-900
          font-semibold rounded-xl hover:from-yellow-500 hover:to-yellow-600
          transition-all shadow-lg hover:shadow-xl transform
          hover:-translate-y-0.5"
          >
            Buy me a coffee
          </a>
        </div>
        <p class="text-xs text-gray-500 mt-3">
          Your support helps keep this tool free and open source ❤️
        </p>
      </div>
    </div>
  </main>

  <!-- Footer -->
  <footer class="border-t border-gray-200 mt-16 py-8 bg-white/50">
    <div class="container mx-auto px-4 text-center text-sm text-gray-600">
      <p>
        Made with 💙 by <a
          href="https://github.com/TU_USUARIO"
          target="_blank"
          rel="noopener noreferrer"
          class="text-blue-600 hover:text-blue-700 font-medium">@tu_usuario</a
        >
      </p>
      <p class="mt-2">
        <a
          href="https://github.com/TU_USUARIO/flutter-graph"
          target="_blank"
          rel="noopener noreferrer"
          class="text-gray-500 hover:text-gray-700 inline-flex items-center gap-1"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path
              fill-rule="evenodd"
              d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
              clip-rule="evenodd"></path>
          </svg>
          View on GitHub
        </a>
      </p>
    </div>
  </footer>
</Layout>
