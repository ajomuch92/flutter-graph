---
import Layout from "../layouts/Layout.astro";
import DependencyGraph from "../components/DependencyGraph.vue";
---

<Layout title="Flutter Graph - Visualizador de dependencias">
  <main class="container mx-auto p-4">
    <h1 class="text-3xl font-bold mb-2 text-center">📦 flutter-graph</h1>
    <p class="text-center text-gray-600 mb-6">
      Explore the dependencies of your Flutter packages with an interactive
      graph visualization. Enter a package name to see its relationships and
      dependencies in a clear, visual format.
    </p>
    <DependencyGraph client:load />
  </main>
</Layout>
