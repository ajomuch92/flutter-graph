---
import Layout from "../layouts/Layout.astro";
import DependencyGraph from "../components/DependencyGraph.vue";
---

<Layout title="Flutter Graph - Graph Visualization for Flutter Packages">
  <main
    class="min-h-screen bg-linear-to-br from-blue-50 via-white to-purple-50"
  >
    <!-- Header -->
    <div class="container mx-auto px-4 py-8">
      <div class="text-center mb-8">
        <div class="inline-flex items-center gap-3 mb-4">
          <div
            class="w-12 h-12 bg-linear-to-br from-blue-600 to-purple-600 rounded-xl flex items-center justify-center shadow-lg"
          >
            <span class="text-2xl">📦</span>
          </div>
          <h1
            class="text-4xl md:text-5xl font-bold bg-linear-to-r from-blue-600 to-purple-600 bg-clip-text text-transparent"
          >
            flutter-graph
          </h1>
        </div>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">
          Explore the dependencies of your Flutter packages with interactive
          visualization. Enter a package name to see its relationships in a
          clear and visual format.
        </p>
      </div>

      <!-- Main Card -->
      <div class="max-w-6xl mx-auto">
        <div
          class="bg-white rounded-2xl shadow-xl border border-gray-100 overflow-hidden"
        >
          <DependencyGraph client:load />
        </div>
      </div>

      <!-- Features -->
      <div class="grid md:grid-cols-3 gap-6 mt-12 max-w-4xl mx-auto">
        <div
          class="bg-white/60 backdrop-blur-sm rounded-xl p-6 border border-gray-200"
        >
          <div class="text-3xl mb-3">🔍</div>
          <h3 class="font-semibold text-gray-900 mb-2">Deep Exploration</h3>
          <p class="text-sm text-gray-600">
            Control the depth of analysis to see dependencies of dependencies
          </p>
        </div>
        <div
          class="bg-white/60 backdrop-blur-sm rounded-xl p-6 border border-gray-200"
        >
          <div class="text-3xl mb-3">📊</div>
          <h3 class="font-semibold text-gray-900 mb-2">Complete Metrics</h3>
          <p class="text-sm text-gray-600">
            Visualize likes, popularity and pub points for each package
          </p>
        </div>
        <div
          class="bg-white/60 backdrop-blur-sm rounded-xl p-6 border border-gray-200"
        >
          <div class="text-3xl mb-3">🎨</div>
          <h3 class="font-semibold text-gray-900 mb-2">Interactive View</h3>
          <p class="text-sm text-gray-600">
            Navigate and explore the graph with zoom, pan and informative
            tooltips
          </p>
        </div>
      </div>
    </div>
  </main>
</Layout>
